{
  "name": "@datopian/ckan-gw-explorer",
  "version": "0.1.0",
  "private": false,
  "description": "React component for exploring and visualizing CKAN datasets with Graphic Walker.",
  "license": "MIT",
  "author": "OKNP <sagarg@oknp.org>",
  "homepage": "https://github.com/datopian/ckan-gw-explorer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/datopian/ckan-gw-explorer.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/datopian/ckan-gw-explorer/issues"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ckan",
    "data-visualization",
    "graphic-walker",
    "react",
    "typescript"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@kanaries/graphic-walker": ">=0.5.0-alpha.4"
  },
  "devDependencies": {
    "@kanaries/graphic-walker": "0.5.0-alpha.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "rollup": "^3.29.5",
    "rollup-plugin-dts": "^5.3.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-css-only": "^4.5.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build"
  }
}
