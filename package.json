{
  "name": "ckan-gw-explorer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/example"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/core",
    "example": "npm run start --workspace=packages/example",
    "example:dev": "npm run start-with-sync --workspace=packages/example",
    "build:all": "npm run build --workspaces",
    "clean": "rm -rf node_modules packages/*/node_modules packages/*/dist",
    "install:all": "npm install --workspaces"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "styled-components": "^6.1.19"
  },
  "overrides": {
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "ajv": "^8.17.1"
  }
}
